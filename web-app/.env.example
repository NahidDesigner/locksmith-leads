# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# Single admin auth. Set these once.
ADMIN_EMAIL=admin@example.com
# Generate via `http://localhost:3000/api/hash?password=YourPassword` after npm run dev.
# Format: scrypt:<salt_b64url>:<hash_b64url> — safe to paste without quoting.
ADMIN_PASSWORD_HASH=scrypt:xxxx:xxxx
# 48+ random bytes, base64url-safe (no + / = characters).
SESSION_SECRET=xxxx
